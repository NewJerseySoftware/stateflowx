{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "declaration": true,

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "types": ["node"]
  },

  "include": ["src/**/*.ts"]
}
